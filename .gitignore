# ─────────────────────────────────────────────────────────────

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
eggs/
*.egg-info/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual Environments ──────────────────────────────────────
venv/
env/
.venv/
ENV/
.env/
.direnv/

# ── FAISS Index (auto-generated by ingestor.py — do not commit) ──
faiss_index/
faiss_index/index.faiss
faiss_index/chunks.pkl
*.faiss
*.pkl
*.index

# ── PDF Source Data (large binary — share via link, not git) ──
data/
data/*.pdf
data/*.PDF
*.pdf

# ── Jupyter / IPython ─────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ── Logs & Temp ───────────────────────────────────────────────
*.log
*.tmp
*.temp
logs/
tmp/
temp/
.cache/

# ── Coverage & Testing ────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ── MyPy ──────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Node (if any frontend build tools are added) ──────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── What IS committed (reference) ────────────────────────────
# backend/main.py
# backend/ingestor.py
# backend/retriever.py
# backend/agent.py
# backend/models.py
# frontend/index.html
# frontend/style.css
# frontend/app.js
# requirements.txt
# README.md
# .env.example        ← add this file with placeholder keys only
